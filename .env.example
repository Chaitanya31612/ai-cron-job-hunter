# =============================================================
# AI Job Hunter — Environment Configuration
# Copy this file to .env and fill in your real keys.
# .env is gitignored and will NEVER be committed.
# =============================================================

# --- Google AI Studio (Primary LLM) ---
# Get your key at: https://aistudio.google.com/
# Use a project with NO billing linked to keep the 500 RPD free tier.
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenRouter (Fallback 1 & 2 — Free Models) ---
# Get your key at: https://openrouter.ai/ (no credit card required)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Groq (Last Fallback) ---
# Get your key at: https://console.groq.com/ (no credit card required)
GROQ_API_KEY=your_groq_api_key_here

# --- Telegram Bot Notifications ---
# 1. Create a bot via @BotFather on Telegram → copy the token below
# 2. Create TWO Telegram groups/channels and add your bot to both
# 3. For each channel, message the bot then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Find "chat" → "id" and paste below
#
#  HIGH = score 8+ ("🔥 apply now" queue)
#  LOW  = score 6-7 ("👀 review later" queue)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID_HIGH=your_high_priority_chat_id_here
TELEGRAM_CHAT_ID_LOW=your_regular_chat_id_here
